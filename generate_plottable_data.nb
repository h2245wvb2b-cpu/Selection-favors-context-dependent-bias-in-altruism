           "1"}], ",", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"deltas", " ", "=", " ", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{
                RowBox[{
