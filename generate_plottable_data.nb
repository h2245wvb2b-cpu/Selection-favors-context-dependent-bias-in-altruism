Cell[BoxData[{
 RowBox[{
  RowBox[{"allvectors", "=", 
   RowBox[{"Flatten", "[", 
    RowBox[{"vectors", ",", "1"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"sortbyscaler", " ", "=", " ", 
   RowBox[{"Sort", "[", 
    RowBox[{"allvectors", ",", " ", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"#1", "[", 
         RowBox[{"[", "1", "]"}], "]"}], "[", 
        RowBox[{"[", "1", "]"}], "]"}], "<", 
       RowBox[{
        RowBox[{"#2", "[", 
         RowBox[{"[", "1", "]"}], "]"}], "[", 
        RowBox[{"[", "1", "]"}], "]"}]}], "&"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"partitionss", "=", 
   RowBox[{"BinCounts", "[", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"Transpose", "[", 
        RowBox[{"sortbyscaler", "[", 
         RowBox[{"[", "All", "]"}], "]"}], "]"}], "[", 
       RowBox[{"[", "1", "]"}], "]"}], "[", 
      RowBox[{"[", 
       RowBox[{"All", ",", "1"}], "]"}], "]"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"0", ",", " ", "maxscaler", ",", 
       RowBox[{"maxscaler", "/", "partitiongrid"}]}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"binnedcoords", "=", 
   RowBox[{"TakeList", "[", 
    RowBox[{"sortbyscaler", ",", "partitionss"}], "]"}]}], ";"}]}], "Input",
